# Vercel Environment Variables
# Copy these variables to Vercel Dashboard → Settings → Environment Variables
# Replace all placeholder values with your actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Django Secret Key (REQUIRED)
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ux$@m+v)wz0b$giik!-^%f=lh9a1(6kj$8b2w&spl07fn10=!-

# Database Connection (REQUIRED)
# Get this from Supabase Dashboard → Settings → Database → Connection Pooling → Session mode
# Format: postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.emqcixyklluxufekncir:Sakora121991aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Debug Mode (REQUIRED)
# Set to False for production
