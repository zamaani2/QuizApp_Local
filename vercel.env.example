# Vercel Environment Variables
# Copy these variables to Vercel Dashboard → Settings → Environment Variables
# Replace all placeholder values with your actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Django Secret Key (REQUIRED)
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-SECURE-RANDOM-KEY

# Database Connection (REQUIRED)
# Get this from Supabase Dashboard → Settings → Database → Connection Pooling → Session mode
# Format: postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Debug Mode (REQUIRED)
# Set to False for production
DEBUG=False

# Allowed Hosts (REQUIRED)
# Replace 'your-app' with your actual Vercel app name
# Vercel will also set VERCEL_URL automatically
ALLOWED_HOSTS=your-app.vercel.app,*.vercel.app

# Site URL (REQUIRED)
# Replace with your actual Vercel URL
SITE_URL=https://your-app.vercel.app

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Email Settings (Optional)
# Configure if you need email functionality
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Alternative Database Configuration (Optional)
# Only use if not using DATABASE_URL
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=db.xxx.supabase.co
# DB_PORT=5432

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy each variable above (without the # comment)
# 2. Replace placeholder values with your actual values
# 3. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 4. Add each variable one by one, or use Vercel CLI (see below)
# 5. After adding variables, redeploy your project

# ============================================
# USING VERCEL CLI (Alternative Method)
# ============================================
# You can also set variables using Vercel CLI:
#
# vercel env add SECRET_KEY
# vercel env add DATABASE_URL
# vercel env add DEBUG
# vercel env add ALLOWED_HOSTS
# vercel env add SITE_URL
#
# Or create a .env.local file and use:
# vercel env pull .env.local
# Then manually add to Vercel dashboard

